# Copy this file to .env and fill in your private credentials.
ZOTERO_API_KEY=your-zotero-api-key
ZOTERO_USER_ID=your-zotero-user-id
ZOTERO_API_BASE=https://api.zotero.org
API_VERSION=3
RATE_LIMIT_DELAY=2.0
BATCH_SIZE=5
CYCLE_DELAY=60
CREATOR_LOG_PATH=creator.log
ADDNEW_LOG_PATH=api_v2_service.log
INSPECTOR_LOG_PATH=api_service.log
ATTACHMENT_PAIRS_PATH=attachment_pairs.json

# WebSocket Streaming Configuration
WEBSOCKET_ENABLED=true              # Use Zotero Streaming API (event-driven instead of polling)
FALLBACK_POLL_INTERVAL=600          # Fallback poll interval in seconds if no stream events (default: 10 min)
FALLBACK_POLL_ENABLED=true          # Enable fallback polling (set false for stream-only mode)

# Zotero Translation Server (metadata extraction from URLs and identifiers)
# Uses same translators as the Zotero browser connector
# For self-hosted: docker run -d -p 1969:1969 zotero/translation-server
TRANSLATION_SERVER_URL=https://t0guvf0w17.execute-api.us-east-1.amazonaws.com/Prod
TRANSLATION_TIMEOUT=30

# Pipeline Configuration
TMP_DIR=/Users/travisross/DEVONzot/tmp_extractions
EXTRACTION_TIMEOUT=120
DEBUG_MODE=false

# Article Extraction Fallback Configuration
# Three-tier cascading fallback system for maximum extraction success rate
ENABLE_RSS_FALLBACK=true         # Tier 1: RSS/Atom feeds (Substack, Medium, WordPress)
ENABLE_PLAYWRIGHT=false          # Tier 2: Browser automation (requires: pip install playwright && playwright install chromium)
ENABLE_WAYBACK=true              # Tier 3: Internet Archive snapshots (paywalled/deleted content)
PLAYWRIGHT_TIMEOUT=30000         # Playwright page load timeout in milliseconds
WAYBACK_TIMEOUT=15               # Wayback Machine API timeout in seconds
